# === NIEKADA nekommitink .env — tik šis šablonas ===

# GitHub: https://github.com/settings/tokens → classic → repo
GITHUB_TOKEN=
GITHUB_USER=tkliucinskas-create
GITHUB_REPO=canvas

# Vercel CLI: https://vercel.com/account/tokens → Create → tipo turi būti
# „Personal Access Token“ (prefiksas vcp_), NE „API Key“ (vck_) — CLI nepriima vck_
VERCEL_TOKEN=
